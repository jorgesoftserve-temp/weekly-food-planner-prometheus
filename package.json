{
  "name": "recipe-box",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@9.12.3",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm --filter @recipe-box/web test",
    "db:reset": "pnpm --filter @recipe-box/supabase db:reset",
    "db:gen:types": "pnpm --filter @recipe-box/supabase db:gen:types",
    "record": "node --env-file=apps/web/.env.local scripts/record-demo.mjs",
    "e2e": "node --env-file=apps/web/.env.local scripts/audit.mjs"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "playwright": "^1.49.0",
    "typescript": "^5.7.2"
  }
}
