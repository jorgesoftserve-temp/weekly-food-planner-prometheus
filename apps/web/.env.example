# ── Supabase ──────────────────────────────────────────────────────────────────
# Get these from your Supabase project settings → API.
# For local dev run `pnpm --filter @recipe-box/supabase db:start` and copy
# the values printed under "API URL" and "anon key" / "service_role key".

# Public — exposed to the browser bundle (NEXT_PUBLIC_ prefix required).
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# Private — server-side only. Never expose this to the client.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>
